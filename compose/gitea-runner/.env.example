# Gitea Actions runner

TZ=Europe/Zurich

# How the runner reaches the Gitea server. Both containers share the
# `gitea-net` Docker network so we can address by container name.
GITEA_INSTANCE_URL=http://gitea:3000

# One-time token from Gitea -> Site Administration -> Actions -> Runners ->
# "Create new Runner". Consumed on first start, then the token in
# `data/.runner` takes over and this can be unset.
GITEA_RUNNER_REGISTRATION_TOKEN=

# Display name in the Gitea Runners UI. Per-host so multi-runner deployments
# stay distinguishable.
GITEA_RUNNER_NAME=airbase-runner-01
