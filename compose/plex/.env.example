# Plex Media Server
# Reachable on LAN + Tailscale only — no public ingress.

# Plex claim token used on first start to bind the server to a Plex.tv account.
# Get one at https://www.plex.tv/claim/ — single-use, expires in ~4 minutes.
# After the first successful run this can be unset; the bound identity lives
# in ./config/Library/Application Support/Plex Media Server/Preferences.xml.
PLEX_CLAIM=
