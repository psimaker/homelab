# crawl4ai — headless web extraction with LLM post-processing
# Cluster-internal + LOOGI consumer; not publicly published.

# Image tag — pin to "latest" for rolling, or a specific tag like "0.4.245"
# for deterministic deploys.
TAG=latest

# Authentication for the HTTP API. When set, every /crawl request must include
# `Authorization: Bearer <token>`. LOOGI's SearXNG-side connector reads this
# from its own SOPS-encrypted secret and injects the same token.
CRAWL4AI_API_TOKEN=                      # generate: openssl rand -hex 32
