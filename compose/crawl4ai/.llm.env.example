# LLM provider credentials consumed by crawl4ai's extraction strategies.
# crawl4ai loads this file via `env_file:`; it's distinct from the .env that
# Compose reads for variable interpolation. Only populate the providers you
# actually use; the rest can stay empty.

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_API_KEY=
MISTRAL_API_KEY=
