# n8n — workflow automation
# Public domain: n8n.psimaker.org

# Postgres backing store for n8n
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=                       # generate: openssl rand -base64 24

# Built-in basic auth in front of the editor UI. Belt-and-braces alongside
# Cloudflare Access; either one alone is enough.
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=                     # admin username
N8N_BASIC_AUTH_PASSWORD=                 # generate: openssl rand -base64 24

# Public URL knobs — n8n needs to know its own externally-visible URL so
# webhook nodes generate correct URLs.
N8N_HOST=n8n.psimaker.org
WEBHOOK_URL=https://n8n.psimaker.org/

# Logging verbosity: error | warn | info | debug
N8N_LOG_LEVEL=info
