# Gitea — self-hosted Git + Actions
# Public domain: git.psimaker.org
# SSH:           ssh://git@git.psimaker.org:2222/<org>/<repo>.git

TZ=Europe/Zurich

# UID/GID that owns ./gitea/data on the host. Match these to the airbase
# user that runs Compose (1000:1000 on this box).
USER_UID=1000
USER_GID=1000

# Image pins. Defaults in compose.yml are sane; override here if you want to
# follow a different track (e.g. nightly).
POSTGRES_IMAGE=postgres:16
GITEA_IMAGE=gitea/gitea:1.24

# Postgres backing store
POSTGRES_DB=gitea
POSTGRES_USER=gitea
POSTGRES_PASSWORD=                       # generate: openssl rand -base64 24

# How Gitea advertises itself in clone URLs, OAuth redirects, webhook URLs.
GITEA_DOMAIN=git.psimaker.org
GITEA_ROOT_URL=https://git.psimaker.org/
GITEA_SSH_PORT=2222

# Three keys Gitea generates internally — must be set BEFORE first start, and
# must NEVER change once data exists (rotating them invalidates every session
# token, repo signing key, and OAuth client secret in the DB).
#
# Generate fresh values once during bootstrap:
#   docker run --rm gitea/gitea:1.24 gitea generate secret SECRET_KEY
#   docker run --rm gitea/gitea:1.24 gitea generate secret INTERNAL_TOKEN
#   docker run --rm gitea/gitea:1.24 gitea generate secret JWT_SECRET
GITEA_SECRET_KEY=
GITEA_INTERNAL_TOKEN=
GITEA_JWT_SECRET=
