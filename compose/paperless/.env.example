# Paperless-ngx — document archive
# Public domain: docs.example.com

TZ=Europe/Zurich

# Image pins. Renovate watches the comments above each `image:` line in
# compose.yml and bumps these tags via PR.
REDIS_IMAGE=docker.io/library/redis:7
POSTGRES_IMAGE=docker.io/library/postgres:16
TIKA_IMAGE=docker.io/apache/tika:latest
GOTENBERG_IMAGE=docker.io/gotenberg/gotenberg:8
PAPERLESS_IMAGE=ghcr.io/paperless-ngx/paperless-ngx:latest
PAPERLESS_GPT_IMAGE=ghcr.io/icereed/paperless-gpt:latest

# UID/GID for files written into the consume/media volumes
USERMAP_UID=1000
USERMAP_GID=1000

# Postgres
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=                       # generate: openssl rand -base64 24

# Internal connection strings — point at the service names from compose.yml
PAPERLESS_REDIS=redis://paperless-redis:6379
PAPERLESS_DBHOST=paperless-db
PAPERLESS_DBPORT=5432
PAPERLESS_DBNAME=paperless
PAPERLESS_DBUSER=paperless
PAPERLESS_DBPASS=                        # same as POSTGRES_PASSWORD above

# Public URL and Django security
PAPERLESS_URL=https://docs.example.com
PAPERLESS_SECRET_KEY=                    # generate: openssl rand -base64 64
PAPERLESS_ALLOWED_HOSTS=docs.example.com,localhost
PAPERLESS_CSRF_TRUSTED_ORIGINS=https://docs.example.com
PAPERLESS_CORS_ALLOWED_HOSTS=https://docs.example.com

# Reverse-proxy hints — NPM terminates TLS, Paperless trusts X-Forwarded-Proto
PAPERLESS_USE_X_FORWARD_HOST=true
PAPERLESS_PROXY_SSL_HEADER=["HTTP_X_FORWARDED_PROTO","https"]
PAPERLESS_ACCOUNT_DEFAULT_HTTP_PROTOCOL=https

# Locale and OCR
PAPERLESS_TIME_ZONE=Europe/Zurich
PAPERLESS_OCR_LANGUAGE=deu
PAPERLESS_OCR_LANGUAGES=deu eng
PAPERLESS_DATE_PARSER_LANGUAGES=de en

# Worker pool sizing — tuned for airbase's 32 threads
PAPERLESS_TASK_WORKERS=4
PAPERLESS_THREADS_PER_WORKER=2
PAPERLESS_WEBSERVER_WORKERS=2

# Audit log every change to a document
PAPERLESS_AUDIT_LOG_ENABLED=true

# Consumer behaviour for the watch folder
PAPERLESS_CONSUMER_RECURSIVE=true
PAPERLESS_CONSUMER_SUBDIRS_AS_TAGS=true
PAPERLESS_CONSUMER_DELETE_DUPLICATES=true

# Tika + Gotenberg are enabled via the optional-doc-conversion profile
PAPERLESS_TIKA_ENABLED=true
PAPERLESS_TIKA_ENDPOINT=http://paperless-tika:9998
PAPERLESS_TIKA_GOTENBERG_ENDPOINT=http://paperless-gotenberg:3000

# ---- paperless-gpt — opt-in via the `ai` profile -----------------------

# How paperless-gpt reaches paperless-web
PAPERLESS_BASE_URL=http://paperless-web:8000
PAPERLESS_PUBLIC_URL=https://docs.example.com
PAPERLESS_API_TOKEN=                     # create in Paperless: Settings -> API tokens

# Tag triggers
MANUAL_TAG=paperless-gpt
AUTO_TAG=paperless-gpt-auto
PAPERLESS_GPT_REVIEW_TAG=paperless-gpt-review
PAPERLESS_GPT_DONE_TAG=paperless-gpt-done
PAPERLESS_GPT_NEEDS_REVIEW_TAG=paperless-gpt-needs-review

# Safety toggles
CREATE_NEW_TAGS=true
AUTO_GENERATE_TITLE=true
AUTO_GENERATE_TAGS=true
AUTO_GENERATE_CORRESPONDENTS=true
AUTO_GENERATE_DOCUMENT_TYPE=true
AUTO_GENERATE_CREATED_DATE=true
PDF_UPLOAD=false
PDF_REPLACE=false
PDF_COPY_METADATA=false
PDF_OCR_TAGGING=false
PDF_OCR_COMPLETE_TAG=
PDF_SKIP_EXISTING_OCR=true

# LLM provider config
LLM_PROVIDER=openai
LLM_MODEL=deepseek-chat
LLM_LANGUAGE=de
LLM_REQUESTS_PER_MINUTE=20
LLM_MAX_RETRIES=3
LLM_BACKOFF_MAX_WAIT=60
TOKEN_LIMIT=128000
LOG_LEVEL=info
LISTEN_INTERFACE=:8080

# Provider creds — only the ones for your chosen LLM_PROVIDER need values
OPENAI_API_KEY=                          # DeepSeek via OpenAI-compat
OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_API_TYPE=
OLLAMA_HOST=
GOOGLEAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
