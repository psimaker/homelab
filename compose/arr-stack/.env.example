# arr-stack — Gluetun-anchored media automation
# Reachable on LAN + Tailscale only — never public.
#
# Topology: gluetun is a WireGuard tunnel container; sabnzbd / radarr / sonarr
# / prowlarr / bazarr / flaresolverr / umlautadaptarr / configarr all share its
# network namespace via `network_mode: service:gluetun`. If gluetun's tunnel
# drops, those containers lose all network access — the kill-switch is exactly
# the property we want for index/torrent traffic.
#
# tdarr / seerr / maintainerr live outside the tunnel because they don't talk
# to indexers; they sit on `arr_network` and (where exposed) `proxy-net`.

TZ=Europe/Zurich
PUID=1000
PGID=1000

# ---- Gluetun / VPN -----------------------------------------------------
# Gluetun supports many providers; we use ProtonVPN over WireGuard.
# See https://github.com/qdm12/gluetun-wiki for the full provider matrix.
VPN_SERVICE_PROVIDER=protonvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=                   # base64 — from your provider's WG config
SERVER_COUNTRIES=Switzerland,Germany,Netherlands

# Subnets the firewall lets pass without going through the tunnel. Add the
# Docker bridge network and the LAN so containers can reach Plex/NPM/etc.
FIREWALL_OUTBOUND_SUBNETS=192.168.8.0/24,172.16.0.0/12

# ---- API keys --------------------------------------------------------
# umlautadaptarr fixes German umlaut transliteration in Radarr/Sonarr names.
# Generate the keys in each app's UI: Settings -> General -> Security.
RADARR_API_KEY=                          # from Radarr UI
SONARR_API_KEY=                          # from Sonarr UI
