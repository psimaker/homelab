# Immich — photo library, CUDA-accelerated ML
# Public domain: photos.example.com

# Where the original photos+videos live. On airbase this is on the 16 TB HDD
# under /mnt/hdd/photos.
UPLOAD_LOCATION=/mnt/hdd/photos

# Postgres data directory — kept on NVMe for IOPS, separate from media
DB_DATA_LOCATION=/data/immich/postgres

TZ=Europe/Zurich

# Tag for ghcr.io/immich-app/immich-server. Use "release" for rolling, or pin
# to a specific tag like "v1.118.2" for stability.
IMMICH_VERSION=release

# Postgres
DB_PASSWORD=                             # generate: openssl rand -base64 24
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
