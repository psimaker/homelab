# Top-level shared variables — most stacks reference these via per-stack .env
# files; the values below are copied into each stack's local .env by Ansible.

# Timezone for all containers; Europe/Zurich at home, kept Europe/Berlin in
# some legacy stacks because the volumes were created with that locale and
# changing it would cause time-jump artefacts in scheduled jobs.
TZ=Europe/Zurich

# UID/GID that owns mounted volumes on airbase. Both are 1000 (the only
# non-root human on the host). Linuxserver.io images respect PUID/PGID;
# Paperless uses USERMAP_UID/USERMAP_GID; *arr stack uses PUID/PGID.
PUID=1000
PGID=1000

# Used for container labels and ownership tracking. Public on the GitHub
# profile, but every consuming stack reads it from a variable so a single
# rotation point exists.
ADMIN_EMAIL=umut.erdem@protonmail.com

# Public second-level domain for the personal services. Tier-2 stacks
# advertise as <service>.${BASE_DOMAIN} via Nginx Proxy Manager.
BASE_DOMAIN=psimaker.org
