# ntfy — push notification service
# Public domain: ntfy.psimaker.org

TZ=Europe/Zurich

# How ntfy advertises itself in subscription URLs and instance metadata
NTFY_BASE_URL=https://ntfy.psimaker.org

# Persistent message cache and auth database
NTFY_CACHE_FILE=/var/lib/ntfy/cache.db
NTFY_AUTH_FILE=/var/lib/ntfy/auth.db

# `deny-all` means topics aren't readable/writable without an explicit ACL.
# Combined with NTFY_ENABLE_LOGIN=true this gives a private instance with
# per-topic permissions managed by `ntfy user`/`ntfy access`.
NTFY_AUTH_DEFAULT_ACCESS=deny-all
NTFY_ENABLE_LOGIN=true

# We sit behind Nginx Proxy Manager; trust X-Forwarded-* so rate-limit per-IP
# works correctly.
NTFY_BEHIND_PROXY=true

# Upstream relay used for iOS push without a self-hosted APNs cert
NTFY_UPSTREAM_BASE_URL=https://ntfy.sh

# Where uploaded attachments live (when --attachment-* flags or topic perms
# allow uploads). Same volume as the auth/cache DBs.
NTFY_ATTACHMENT_CACHE_DIR=/var/lib/ntfy/attachments
