# Watchtower — opt-in image updater for labelled containers
#
# Schedule: every 3 days at 04:00 (cron `0 0 4 */3 * *`).
# Only acts on containers with label com.centurylinklabs.watchtower.enable=true.

# Where to post the update digest after each run. We use the same ntfy
# instance the rest of the stack uses; the topic is a private one so the
# token is part of the URL (Shoutrrr ntfy:// scheme).
#
# Format: ntfy://<token>@ntfy.psimaker.org/<topic>
# Example (redacted): ntfy://tk_xxxxxxxxxxxx@ntfy.psimaker.org/homelab-watchtower
WATCHTOWER_NTFY_URL=
