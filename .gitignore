# Local secrets — never commit plaintext
*.env
.env
.env.local
*.key
*.pem
*.pfx
secrets/
!**/secrets/.gitkeep

# Encrypted secrets are committed (SOPS); plaintext copies must not be
*.dec.yaml
*.dec.yml
*.dec.json
*-decrypted.*

# Terraform / OpenTofu
**/.terraform/*
**/.terraform.lock.hcl.bak
**/terraform.tfstate
**/terraform.tfstate.*
**/.terraformrc
**/terraform.rc
**/crash.log
**/crash.*.log
**/override.tf
**/override.tf.json
**/*_override.tf
**/*_override.tf.json
**/.terraform.tfstate.lock.info
**/*.tfvars
!**/*.tfvars.sops.json
!**/*.tfvars.example

# Ansible
ansible/.vault_pass
ansible/*.retry
ansible/inventory/group_vars/*.dec.yml
ansible/.galaxy_install_info

# kubectl/k3s/flux
kubeconfig
kubeconfig.*
*.kubeconfig
.flux-system/

# Tooling caches
.cache/
.venv/
.python-version
__pycache__/
node_modules/

# Editors
.idea/
.vscode/
!.vscode/extensions.json
*.swp
*~
.DS_Store
Thumbs.db

# OS / build artefacts
*.log
*.tmp
*.bak

# Local working directories not meant for upstream
local/
scratch/
.local/
