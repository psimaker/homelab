---
profile: production

exclude_paths:
  - collections/
  - .ansible_facts/
  - .galaxy_install_info
  - inventory/group_vars/all.sops.yml

# Bundled inventory has a single-host group named like its host (`edge`).
# That's intentional — the brief asks the group_vars file to be `edge.yml`.
warn_list:
  - var-naming[no-role-prefix]    # role-internal helper vars stay short
  - role-name                     # we use `_` in role names by convention

skip_list: []

mock_modules:
  - community.sops.sops_decrypt
