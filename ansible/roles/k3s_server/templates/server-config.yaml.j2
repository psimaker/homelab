# Managed by Ansible — roles/k3s_server. Do not edit by hand.
# Reference: https://docs.k3s.io/installation/configuration#configuration-file
write-kubeconfig-mode: "0640"
cluster-cidr: "{{ k3s_cluster_cidr }}"
service-cidr: "{{ k3s_service_cidr }}"
cluster-dns: "{{ k3s_cluster_dns }}"
advertise-address: "{{ k3s_server_advertise_address }}"
node-ip: "{{ k3s_server_node_ip }}"
node-external-ip: "{{ k3s_server_node_ip }}"
flannel-backend: "none"
disable-network-policy: true
disable:
{% for c in k3s_server_disable_components %}
  - {{ c }}
{% endfor %}
tls-san:
  - "edge.tailnet"
  - "hs.example.com"
  - "{{ tailscale_ip }}"
node-label:
  - "topology.kubernetes.io/zone=hetzner-fsn1"
  - "node-role.kubernetes.io/control-plane=true"
kubelet-arg:
  - "max-pods=110"
  - "system-reserved=cpu=200m,memory=256Mi"
kube-controller-manager-arg:
  - "bind-address=0.0.0.0"
kube-scheduler-arg:
  - "bind-address=0.0.0.0"
