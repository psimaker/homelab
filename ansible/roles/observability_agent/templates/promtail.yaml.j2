# Managed by Ansible — roles/observability_agent. Do not edit by hand.
server:
  http_listen_address: "{{ promtail_listen_addr.split(':')[0] }}"
  http_listen_port: {{ promtail_listen_addr.split(':')[1] }}
  grpc_listen_port: 0

positions:
  filename: {{ promtail_positions_path }}

clients:
  - url: {{ promtail_loki_url }}
    external_labels:
{% for k, v in promtail_external_labels.items() %}
      {{ k }}: "{{ v }}"
{% endfor %}

scrape_configs:
  - job_name: system
    static_configs:
      - targets:
          - localhost
        labels:
          job: varlogs
          host: "{{ inventory_hostname }}"
          __path__: /var/log/{syslog,auth.log,kern.log}

{% for path in promtail_scrape_paths %}
  - job_name: file-{{ path | basename | regex_replace('\\.', '-') }}
    static_configs:
      - targets:
          - localhost
        labels:
          job: {{ path | basename }}
          host: "{{ inventory_hostname }}"
          __path__: {{ path }}
{% endfor %}

{% if promtail_scrape_docker %}
  - job_name: docker
    docker_sd_configs:
      - host: {{ promtail_docker_socket }}
        refresh_interval: 5s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: container
      - source_labels: ['__meta_docker_container_log_stream']
        target_label: stream
      - source_labels: ['__meta_docker_container_label_com_docker_compose_project']
        target_label: compose_project
      - source_labels: ['__meta_docker_container_label_com_docker_compose_service']
        target_label: compose_service
{% endif %}
